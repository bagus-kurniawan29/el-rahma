{
  "version": 2,
  "framework": null,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/profil/?",
      "dest": "/api/profil.php"
    },
    {
      "src": "/profil.php",
      "dest": "/api/profil.php"
    },
    {
      "src": "/layanan/?",
      "dest": "/api/layanan.php"
    },
    {
      "src": "/layanan.php",
      "dest": "/api/layanan.php"
    },
    {
      "src": "/portofolio/?",
      "dest": "/api/portofolio.php"
    },
    {
      "src": "/portofolio.php",
      "dest": "/api/portofolio.php"
    },
    {
      "src": "/kontak/?",
      "dest": "/api/kontak.php"
    },
    {
      "src": "/kontak.php",
      "dest": "/api/kontak.php"
    },
    {
      "src": "/(login|register|logout|dashboard|export)(\\.php)?/?",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
