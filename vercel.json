{
  "version": 2,
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.1" },
    "*.php": { "runtime": "vercel-php@0.7.1" },
    "includes/**/*.php": { "runtime": "vercel-php@0.7.1" }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/profile",
      "dest": "/profile.php"
    },
    {
      "src": "/portfolio",
      "dest": "/portfolio.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}