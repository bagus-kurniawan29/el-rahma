{
  "version": 2,
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.7.1" },
    { "src": "includes/**/*.php", "use": "vercel-php@0.7.1" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/data/(.*)",
      "dest": "/data/$1"
    },
    {
      "src": "/profil",
      "dest": "/profil.php"
    },
    {
      "src": "/portofolio",
      "dest": "/portofolio.php"
    },
    {
      "src": "/layanan",
      "dest": "/layanan.php"
    },
    {
      "src": "/kontak",
      "dest": "/kontak.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}