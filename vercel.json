{
  "version": 2,
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.7.1" },
    "api/includes/**/*.php": { "runtime": "vercel-php@0.7.1" }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/data/(.*)",
      "dest": "/data/$1"
    },
    {
      "src": "/profil",
      "dest": "/api/profil.php"
    },
    {
      "src": "/portofolio",
      "dest": "/api/portofolio.php"
    },
    {
      "src": "/layanan",
      "dest": "/api/layanan.php"
    },
    {
      "src": "/kontak",
      "dest": "/api/kontak.php"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}