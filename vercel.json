{
  "version": 2,
  "build": {
    "env": {
      "PHP_VERSION": "8.2"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/data/(.*)",
      "dest": "/data/$1"
    },
    {
      "src": "/profil",
      "dest": "/profil.php"
    },
    {
      "src": "/portofolio",
      "dest": "/portofolio.php"
    },
    {
      "src": "/layanan",
      "dest": "/layanan.php"
    },
    {
      "src": "/kontak",
      "dest": "/kontak.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}